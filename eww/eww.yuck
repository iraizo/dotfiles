;;The Bar widget, which fills the bar window and houses all content
;;----------------------------------------------------------------
(defwidget bar []
  (centerbox
    :orientation "h"
    (bars)
    (music)
    (timedate)
  )
)

;;Time/date widget creation
;;----------------------------------------------------------------
(defwidget timedate []
  (button
    :class "timedate"
    :orientation "h"
    :halign "end"

    time
  )
)

;;Widget for the RAM, Volume bars
;;----------------------------------------------------------------
(defwidget bars []
  (box
    :onclick "eww open calendar"

    :class "bars"
    :orientation "h"
    :space-evenly false
    :halign "start"
    ;;commented out bc it's broken
    (metric
      :label ""
      :value {EWW_CPU.avg}
      :onchange ""
    )
    ;;Ram Usage
    (metric
      :label ""
      :value {EWW_RAM.used_mem_perc}
      :onchange ""
    )
 (box
    :orientation "h"
    :class "metric"
    :space-evenly false
    (box
      :class "label"
      "🔊"
    )
    (scale
      :min 0
      :max 100
      :active true
      :value volume
      :onchange "eww update volume={} & amixer -D pulse sset Master {}% / 100"
    )
  )
    ;;Battery
    ;;(metric
      ;;:label "⚡"
      ;;:value {EWW_BATTERY.BAT0.capacity}
      ;;:onchange ""
    )
    ;;Commented out bc broken
;;    (metric
;;     :label "💾"
;;     :value {round((1 - (EWW_DISK["/"].free / EWW_DISK["/"].total)) * 100, 0)}
;;     :onchange ""
;;      )
  )


