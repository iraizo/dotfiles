;;Widget that gives the music title 
;;----------------------------------------------------------------
(defwidget music []
  (button
    :class "music"
    :orientation "h"
    :space-evenly false
    :halign "center"
    :onclick "eww open --toggle mediactrl"
    {music != "" ? "${music}" : ""} ;;🎵 
  )
)

;;Base widget creation/setup for RAM/Volume bars
;;----------------------------------------------------------------
(defwidget metric [label value onchange]
  (box
    :orientation "h"
    :class "metric"
    :space-evenly false
    (box
      :class "label"
      label
    )
    (scale
      :min 0
      :max 100
      :active {onchange != ""}
      :value value
      :onchange onchange
    )
  )
)

;;Definining variables
;;----------------------------------------------------------------
(deflisten music
  :initial ""
  "playerctl --follow metadata --format '{{ title }} - {{ artist }}' || true"
)

(defpoll volume
  :interval ".1s"
  "scripts/getvol"
)

(defpoll time
  :interval "10s"
  "date '+%H:%M  |  %A %b %d, %Y  |  %j'"
)

;;The actual bar itself, the window that houses everything
;;----------------------------------------------------------------
(defwindow bar
  :monitor 1
  :windowtype "dock"
  :exclusive true
  :geometry (
    geometry
    ;;X and Y padding from the top of the screen
    :x "14px"
    :y "14px"
    ;;Width needs to be (monwidth-2x)
    :width "2528px"
    ;;Height can be whatever
    :height "32px"
    :anchor "top center"
  )
  (bar)
)


;;Music Controls panel
;;--------------------------------------------------------------------------------------------------------------------------------
(defvar media false)

;;Windows for the media controls
(defwindow mediactrl
  :monitor 0
  :windowtype "dock"
  :exclusive false
  :focusable false
  :geometry (
    geometry
    :y "16px"
    :width "400px"
    :height "100px"
    :anchor "top center"
  )
  (mediapanel)
)

;;Media Panel Creation
(defwidget mediapanel []
  (box
    :class "mediapanel"
    :orientation "vertical" ;;wain box in the widget window
    ;;Track and artist, didn't like how it looked.
    ;(label
    ;  :class "track"
    ;  :limit-width 20
    ;  :text track)
    ;(label
    ;  :class "artist"
    ;  :text artist)

    (box ;;contains all the media controls
      :orientation "horizontal"
      
      (button
        :class "rewind"
        :onclick "playerctl previous"

      "玲")

      (button
        :class "playpause"
        :onclick "playerctl play-pause"

      "懶")

      (button
        :class "skip"
        :onclick "playerctl next"
      "怜") 
    )
  )
)


;;Desktop Widgets
;;--------------------------------------------------------------------------------------------------------------------------------
(defwindow desktop
  :monitor 0
  :stacking "bg"
  :class "power"
  :geometry (
    geometry
    :width "164px"
    :height "64px"
    :x "16px"
    :y "16px"
    :anchor "bottom right"
  )
  (desktop_container)
)

;;Container for the desktop widgets
(defwidget desktop_container []
  (box
    :class "poweroptions"
    :orientation "horizontal"
    ;;Logout
    (button
      :class "logout"
      :class "powerbuttons"
      :onclick "loginctl terminate-user $USER"
      ""
    )

    ;;Hibernate
    ;;(button
    ;;  :class "hibernate"
    ;;  :class "powerbuttons"
    ;;  :onclick "systemctl hibernate"
    ;;  "⏾"
    ;;)

    ;;Restart
    (button
      :class "restart"
      :class "powerbuttons"
      :onclick "shutdown now -r"
      "ﰇ"
    )

    ;;Shutdown
    (button
      :class "shutdown"
      :class "powerbuttons"
      :onclick "shutdown now -P"
      "襤"
    )
  )
)
